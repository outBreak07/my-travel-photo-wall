# China Photo Wall - Configuration
# Copy this file to .env and fill in your own values

# Server port
PORT=8080

# Auth toggle: true = require login for write operations
AUTH_ENABLED=true

# Default admin account (seeded to DB on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Remote backend API URL (leave empty for local mode)
API_BASE_URL=

# CORS allowed origin (* = all, or specific like https://example.com)
CORS_ORIGIN=*
